# wrangler.toml.example — template for the Cloudflare Workers deploy.
#
# THIS FILE IS A TEMPLATE. Run `./scripts/setup.sh` from the repo root
# and it will:
#
#   1. Copy this file to `wrangler.toml`
#   2. Create the Cloudflare resources (D1, Vectorize, KV, R2)
#   3. Replace the CHANGE_ME_AFTER_SETUP placeholders below with the
#      real resource IDs returned by wrangler
#   4. Generate the OAuth credentials and admin key
#   5. Push everything to your Cloudflare account
#   6. Deploy the worker
#
# Manual deploy (if you'd rather not run the script): copy this file
# to `wrangler.toml` and follow the steps in the README's "Manual
# deploy" appendix.
#
# `wrangler.toml` itself is gitignored — it holds your account-specific
# resource IDs and you don't want to commit them or pull a teammate's
# accidentally.

name = "memoria"
main = "build/worker/shim.mjs"
compatibility_date = "2026-05-01"

[build]
# Rust workers compile to wasm32 via worker-build (installs on demand).
# Requires the `wasm32-unknown-unknown` target installed via rustup.
command = "cargo install -q worker-build && worker-build --release"

# ──────────────────────────────────────────────────────────────────────
# D1 — primary memory store. Replaces the local SQLite file.
# Schema lives in `migrations/`.
# ──────────────────────────────────────────────────────────────────────
[[d1_databases]]
binding = "DB"
database_name = "memoria-db"
database_id = "CHANGE_ME_AFTER_SETUP"

# ──────────────────────────────────────────────────────────────────────
# Vectorize — vector index for semantic recall. bge-base-en-v1.5
# produces 768-dim vectors; cosine similarity matches what the
# embedding code expects.
# ──────────────────────────────────────────────────────────────────────
[[vectorize]]
binding = "VECTORS"
index_name = "memoria-vectors"

# ──────────────────────────────────────────────────────────────────────
# Workers AI — bge-base-en-v1.5 embeddings.
# ──────────────────────────────────────────────────────────────────────
[ai]
binding = "AI"

# ──────────────────────────────────────────────────────────────────────
# R2 — content-addressed image storage. Keys are `{hash}.{ext}`.
# ──────────────────────────────────────────────────────────────────────
[[r2_buckets]]
binding = "IMAGES"
bucket_name = "memoria-images"

# ──────────────────────────────────────────────────────────────────────
# KV — OAuth access tokens with TTL.
# ──────────────────────────────────────────────────────────────────────
[[kv_namespaces]]
binding = "TOKENS"
id = "CHANGE_ME_AFTER_SETUP"

# ──────────────────────────────────────────────────────────────────────
# KV — Update-check cache (CLA-102). The recall handler fetches
# VERSION.json from GitHub raw at most every 6h and caches the result
# here. Drives the "update available" prompt attached to recall output.
# ──────────────────────────────────────────────────────────────────────
[[kv_namespaces]]
binding = "VERSION_CACHE"
id = "CHANGE_ME_AFTER_SETUP"

# ──────────────────────────────────────────────────────────────────────
# Cron triggers — two cognitive loops on different schedules.
#
#   REM consolidator (CLA-87)
#     Hebbian clustering + Haiku judgment + additive dispatch.
#     Default: 14:00 UTC (= 00:00 AEST). The setup script rewrites this
#     to match the timezone you choose.
#
#   Dialectic (CLA-95)
#     Calibration scrutiny of recent semantic memories. Stage 1 is
#     judgment-only; Stages 2/3 add adversarial dialogue + actions.
#     Default: 08:00 UTC (= 18:00 AEST). Setup script rewrites for
#     your timezone.
#
# Cron expressions are UTC. If your timezone observes DST, your local
# schedule will shift by an hour seasonally — re-run `./scripts/setup.sh`
# at the boundary to update, or just accept the drift.
# ──────────────────────────────────────────────────────────────────────
[triggers]
crons = ["0 14 * * *", "0 8 * * *"]

# ──────────────────────────────────────────────────────────────────────
# Secrets (set via `wrangler secret put`, not committed):
#
#   CLAUDE_CODE_OAUTH_TOKEN       — long-lived OAuth token from
#                                   `claude setup-token`. Used by REM
#                                   and Dialectic to call Haiku 4.5 on
#                                   the subscription credit pool.
#   MEMORIA_OAUTH_CLIENT_ID       — generated by setup script.
#   MEMORIA_OAUTH_CLIENT_SECRET   — generated by setup script.
#   MEMORIA_ADMIN_KEY             — generated by setup script.
#                                   Used for /admin/import endpoint.
#   MEMORIA_OAUTH_REDIRECT_URIS   — optional; semicolon-separated
#                                   allowlist of OAuth redirect URIs
#                                   (CLA-91 Fix 2). Default covers
#                                   Claude Desktop; add Claude.ai web's
#                                   callback when prompted.
#   MEMORIA_API_KEYS              — optional; semicolon-separated
#                                   role:<argon2-hash> entries for
#                                   embedded clients (CLA-86).
#   MEMORIA_DIALECTIC_DISPATCH    — Stage 3 dispatcher mode. Setup script
#                                   sets "on" for fresh deploys. Override
#                                   to "dry_run" or "off" during burn-in
#                                   or to silence dispatch. Missing or
#                                   unrecognised values fail-closed to
#                                   "dry_run" (CLA-100).
# ──────────────────────────────────────────────────────────────────────
